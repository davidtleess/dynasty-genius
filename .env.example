# Dynasty Genius Databricks / Gateway environment scaffold.
# Copy to a local .env or export these in your host shell.
# Never commit real values.

# Databricks workspace auth for DABs, Unity Catalog, and Model Serving.
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# Zero-trust LLM gateway endpoint fronting Databricks / Azure / AWS routing.
# Use this as the source for ANTHROPIC_BASE_URL in local shells or devcontainers.
ANTHROPIC_DATABRICKS_GATEWAY_URL=

# Optional, if the gateway requires bearer auth separate from Databricks auth.
ANTHROPIC_AUTH_TOKEN=

# Sleeper live roster ingestion.
DYNASTY_SLEEPER_USERNAME=
DYNASTY_SEASON=2026
DYNASTY_SLEEPER_LEAGUE_ID=
DYNASTY_SLEEPER_LEAGUE_NAME=
DYNASTY_SLEEPER_DRAFT_ID=

# CollegeFootballData.com — Patreon Tier 3 required (75k calls/month).
# Key is emailed to the Patreon-linked address after subscribing.
CFBD_API_KEY=

# PlayerProfiler — paid subscription required.
# Used for college prospect stats: target_share, breakout_age, speed_score, yprr.
PLAYERPROFILER_USERNAME=
PLAYERPROFILER_PASSWORD=
