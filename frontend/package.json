{
  "name": "dynasty-genius-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.14.0",
  "scripts": {
    "banned-language": "node scripts/check-banned-language.mjs",
    "build": "vite build",
    "lint": "biome check .",
    "openapi-gen": "../.venv/bin/python3.14 ../scripts/dump_openapi.py && openapi-ts",
    "test": "vitest run --passWithNoTests",
    "test:governance": "npm run banned-language",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@hey-api/openapi-ts": "0.98.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
